# Verify AI - Backend Configuration Example

# Groq API (Obligatoire)
# Obtenez votre clé ici : https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Modèle Groq à utiliser par défaut
GROQ_MODEL=llama-3.3-70b-versatile

# SerpAPI (Obligatoire pour les recherches web réelles)
# Obtenez votre clé ici : https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Configuration Supabase Backend (Service Role) - NEVER EXPOSE THIS IN FRONTEND!
SUPABASE_URL=https://lvqvlydzfcuhiyxpadsr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Configuration du serveur
PORT=3001
CLIENT_URL=http://localhost:5173

# Configuration CORS (optionnel)
# CORS_ORIGIN=*

# Configuration Rate Limiting (optionnel)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=50
